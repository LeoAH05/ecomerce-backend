<div class="row">
  <div class="col-md-6">
    <h2>{{title}}</h2>
    <p>{{description}}</p>
    <p><strong>Precio:</strong> ${{price}}</p>
    <p><strong>Categoría:</strong> {{category}}</p>
    <p><strong>Stock:</strong> {{stock}}</p>
    <p><strong>Código:</strong> {{code}}</p>
    <p><strong>Estado:</strong> {{#if status}}Disponible{{else}}No disponible{{/if}}</p>
  </div>
</div>

<div class="mt-4">
  <h4>Agregar al carrito</h4>
  <input type="text" id="cartId" class="form-control mb-2" placeholder="Ingresá el ID del carrito">
  <button class="btn btn-success" onclick="addToCart('{{_id}}')">Agregar al carrito</button>
</div>

<script>
  async function addToCart(productId) {
    const cartId = document.getElementById("cartId").value;
    if (!cartId) return alert("Ingresá un ID de carrito");

    const res = await fetch(`/api/carts/${cartId}/products/${productId}`, {
      method: "POST"
    });

    const data = await res.json();
    if (data.status === "success") {
      alert("Producto agregado al carrito");
    } else {
      alert("Error al agregar al carrito");
    }
  }
</script>